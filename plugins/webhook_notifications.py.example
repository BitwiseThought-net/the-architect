import requests
from ai_layer.orchestrator import tool
from lib.utils import get_config_value

# --- PLUGIN METADATA ---
INFO = {
    "feature": "webhook_notifications",
    "enabled": True,
    "enabled_for": ["*"],
    "instructions": [
        "To create a Webhook endpoint in Discord...",
        "1. Create a Webhook in Discord (Server Settings -> Integrations -> Webhooks).",
        "2. Copy the Webhook URL.",
        "3. Option A: Enter the URL in the 'SETTINGS' section of this file (Highest Priority).",
        "4. Option B: Add 'NOTIFY_WEBHOOK_URL' to your config.json or .env.",
        "5. This plugin allows agents to send high-priority system alerts."
    ]
}

# --- PLUGIN SETTINGS ---
# Default is empty. If a value is provided here, it takes absolute priority.
SETTINGS = {
    "NOTIFY_WEBHOOK_URL": ""
}

# --- PLUGIN LOGIC (The Webhook Tool) ---
@tool("send_notification")
def send_notification(message: str):
    # Priority 1: Check local SETTINGS first
    webhook_url = SETTINGS.get("NOTIFY_WEBHOOK_URL")
    
    # Priority 2: Fall back to centralized lookup if local is missing, empty, or unconfigured
    if not webhook_url:
        webhook_url = get_config_value("NOTIFY_WEBHOOK_URL")
    
    # Final Validation Guard
    if not webhook_url:
        return "⚠️ Notification skipped: NOTIFY_WEBHOOK_URL is missing or invalid in plugin SETTINGS, config.json, and .env."

    payload = {
        "content": f"📢 **System Alert:** {message}",
        "username": "The-Architect Notifier"
    }

    try:
        response = requests.post(webhook_url, json=payload, timeout=10)
        if response.status_code in [200, 204]:
            return "✅ Webhook notification sent successfully."
        else:
            return f"❌ Webhook failed with status: {response.status_code}"
    except Exception as e:
        return f"❌ Webhook connection error: {str(e)}"

# --- REGISTRATION ---
def register():
    """Provides the webhook tool to the service loader."""
    if not INFO.get("enabled"):
        return None
        
    return {
        "tools": [send_notification],
        "enabled_for": INFO.get("enabled_for", ["*"]),
        "identity_prefix": False 
    }
