# --- CORE CONFIG ---

# Model selection
#MODEL_NAME=qwen2.5-coder:14b
#MODEL_NAME=qwen3-coder-next:latest
#MODEL_NAME=qwen3.6:35b-a3b
MODEL_NAME=qwen3.6:latest

# Ports
LITELLM_PORT=4000
UI_PORT=3011

# --- DUMMY KEYS FOR LOCAL USE ---
# Satisfies Claude Code requirement
ANTHROPIC_API_KEY=ollama

# --- SECURITY & KEYS ---
# Prevents unauthorized access if exposed to network
# Change these to unique random strings!
WEBUI_SECRET_KEY=super_secret_random_string
LITELLM_MASTER_KEY=another_secure_random_string
OPENAI_API_KEY=sk-local-1234
ANTHROPIC_API_KEY=ollama

# --- UI SETTINGS ---
ENABLE_SIGNUP=false

# --- NOTIFICATIONS ---
NOTIFY_WEBHOOK_URL=

# --- INTERNAL NETWORKING ---
# Using service names from docker-compose
OLLAMA_BASE_URL=http://ollama:11434
LITELLM_BASE_URL=http://litellm:4000/v1
